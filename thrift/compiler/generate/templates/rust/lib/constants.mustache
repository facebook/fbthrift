{{#if field:optional?}}){{/if}}
    {{/field}}
  {{/let partial}}

  {{! Nested partials for collection values }}
  {{#let partial list_value |elements| captures |types const_value value depth|}}
    {{#let underlying_type=value.value:underlying_type.type:self}}
    {{#let indent=(indent_4 depth)}}
{
            {{indent}}let mut list = ::std::vec::Vec::new();
    {{#each elements as |elem|}}
            {{indent}}{
                {{indent}}#[inline(never)]
                {{indent}}fn __do_push(list: &mut {{#if underlying_type.has_adapter?}}{{underlying_type.adapter_qualified}}::StandardType{{#else}}{{#partial types.type_name type=underlying_type}}{{/if}}) {
                    {{indent}}list.push({{#partial const_value value=elem depth=(int.add depth 3)}});
                {{indent}}}
                {{indent}}__do_push(&mut list);
            {{indent}}}
    {{/each}}
            {{indent}}list
        {{indent}}}{{!
}}{{/let partial}}
  {{#let partial set_value |elements| captures |types const_value value depth|}}
    {{#let underlying_type=value.value:underlying_type.type:self}}
    {{#let indent=(indent_4 depth)}}
{
            {{indent}}let mut set = {{#if (string.empty? underlying_type.rust_type)}}::std::collections::BTreeSet{{#else}}::{{underlying_type.rust_type}}{{/if}}::new();
              {{#each elements as |elem|}}
            {{indent}}{
                {{indent}}#[inline(never)]
                {{indent}}fn __do_insert(set: &mut {{#if underlying_type.has_adapter?}}{{underlying_type.adapter_qualified}}::StandardType{{#else}}{{#partial types.type_name type=underlying_type}}{{/if}}) {
                    {{indent}}set.insert({{!
                      }}{{#if underlying_type.floating_point?}}{{!
                        }}::fbthrift::export::OrderedFloat({{#partial const_value value=elem depth=(int.add depth 3)}}){{!
                      }}{{#else}}{{!
                        }}{{#partial const_value value=elem depth=(int.add depth 3)}}{{!
                      }}{{/if underlying_type.floating_point?}});
                {{indent}}}
                {{indent}}__do_insert(&mut set);
            {{indent}}}
              {{/each}}
            {{indent}}set
        {{indent}}}{{!
}}{{/let partial}}
  {{#let partial map_value |elements| captures |types const_value value depth|}}
    {{#let underlying_type=value.value:underlying_type.type:self}}
    {{#let indent=(indent_4 depth)}}
{
            {{indent}}let mut map = {{#if (string.empty? underlying_type.rust_type)}}::std::collections::BTreeMap{{#else}}::{{underlying_type.rust_type}}{{/if}}::new();
    {{#each elements as |elem|}}
            {{indent}}{
                {{indent}}#[inline(never)]
                {{indent}}fn __do_insert(map: &mut {{!
                  }}{{#if underlying_type.has_adapter?}}{{underlying_type.adapter_qualified}}::StandardType{{#else}}{{#partial types.type_name type=underlying_type}}{{/if}}) {
                    {{indent}}map.insert({{!
                      }}{{#if underlying_type.floating_point?}}{{!
                        }}::fbthrift::export::OrderedFloat({{#partial const_value value=elem.entry:key depth=(int.add depth 3)}}){{!
                      }}{{#else}}{{!
                        }}{{#partial const_value value=elem.entry:key depth=(int.add depth 3)}}{{!
                      }}{{/if underlying_type.floating_point?}}, {{!
                    }}{{#partial const_value value=elem.entry:value depth=(int.add depth 3)}});
                {{indent}}}
                {{indent}}__do_insert(&mut map);
            {{indent}}}
    {{/each}}
            {{indent}}map
        {{indent}}}{{!
}}{{/let partial}}

  {{! Nested partial for structs (*not* unions) }}
  {{#let partial single_struct_field |field| captures |field_value value depth|}}
    {{#pragma ignore-newlines}}
    {{#let underlying_type=value.value:underlying_type.type:self}}
    {{#field}}
      {{#if field:has_adapter?}}
{{field:adapter_qualified}}::from_thrift_default::<
        {{#if underlying_type.structured?}}
{{underlying_type.true_type.package}}::
{{#if underlying_type.true_type.has_adapter?}}unadapted::{{/if}}
{{underlying_type.true_type.rust_name}}
        {{/if underlying_type.structured?}}
>(
      {{/if field:has_adapter?}}
      {{#if field:explicit_value}}
{{#partial field_value field=field value=field:explicit_value depth=(int.add depth 1)}}
      {{#else if field:default}}
        {{#if (and field:optional? (not (has_compiler_option? "deprecated_optional_with_default_is_some")))}}
::std::option::Option::None
        {{#else}}
{{#partial field_value field=field value=field:default depth=(int.add depth 1)}}
        {{/if (and field:optional? (not (has_compiler_option? "deprecated_optional_with_default_is_some")))}}
      {{#else}}
::std::default::Default::default()
      {{/if field:explicit_value}}
{{#if field:has_adapter?}}, {{field:id}}){{/if}}
    {{/field}}
  {{/let partial}}

  {{#let partial struct_value |elements exhaustive| captures |types single_struct_field value depth|}}
    {{#let underlying_type=value.value:underlying_type.type:self}}
    {{#let indent=(indent_4 depth)}}
{{#partial types.type_name type=underlying_type}} {
    {{#each elements as |elem|}}
            {{indent}}{{elem.field:rust_name}}: {{#partial single_struct_field field=elem}},
    {{/each}}
    {{#if (not exhaustive)}}
            {{indent}}..::std::default::Default::default()
    {{/if (not exhaustive)}}
        {{indent}}}{{!
}}{{/let partial}}

