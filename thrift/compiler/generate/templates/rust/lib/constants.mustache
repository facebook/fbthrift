  {{! Nested partial for circular references `const_value` -> `field_value` -> `const_value` }}
  {{#let partial field_value |field value depth| captures |const_value|}}
{{#pragma ignore-newlines}}
    {{#field}}
{{#if field:optional?}}::std::option::Option::Some({{/if}}
{{#if field:box?}}::std::boxed::Box::new({{/if}}
