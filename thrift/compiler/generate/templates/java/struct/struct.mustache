{{#let export partial struct_equals |struct|}}
@java.lang.Override
public boolean equals(java.lang.Object o) {
    if (this == o) {
        return true;
    }
    if (o == null || getClass() != o.getClass()) {
        return false;
    }

    {{struct.javaCapitalName}} other = ({{struct.javaCapitalName}})o;

    return
        {{#each struct.fields as |field|}}
        {{#if field.hasWrapper?}}
        _{{field.javaName}}_Wrapper.equals({{field.javaName}}, other.{{field.javaName}}) &&
        {{#else if field.hasFieldAdapter?}}
        _{{field.javaName}}_Adapter.equals({{field.javaName}}, other.{{field.javaName}}) &&
        {{#else if field.hasTypeAdapter?}}
        __{{field.type.name}}_Adapter.equals({{field.javaName}}, other.{{field.javaName}}) &&
        {{#else}}
        {{#if (and (string.empty? field.type.javaType) field.type.binary?)}}Arrays{{#else}}Objects{{/if (and (string.empty? field.type.javaType) field.type.binary?)}}.equals({{field.javaName}}, other.{{field.javaName}}) &&
        {{/if field.hasWrapper?}}
        {{/each}}
        true;
}
