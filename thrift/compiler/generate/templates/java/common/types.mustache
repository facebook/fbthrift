{{!
  `type_isAdapterSet` and `field_hasAdapter` are artefacts of mutable properties
  in the corresponding mstch objects, which are *not* shared across instances.
  If they were shared across instances of the mstch object for the AST node, we
  could maintain a shared context across Whisker/mstch keyed by the AST node
  pointer. However, these are instead per mstch object (i.e. transient), and
  mutated in the template.

  This partial isolates that behavior outside the Whisker layer, into the
  non-migrated context. We capture and propagate `field_hasAdapter` recursively,
  as the same `field:hasAdapter?` would be resolved in mstch.
  For `type_isAdapterSet`, we do not propagate it through recursive boxed_type.
  This is because mstch creates new mstch_type instances for `type:typedef_type`
  (equivalent to `.resolved`) and container element types (i.e. `elem_type`,
  `key_type` and `val_type`).
}}
{{#let export partial boxed_type |type field_hasAdapter|}}
  {{#pragma ignore-newlines}}
{{#if type.java_type?}}{{type.java_type}}
{{#else if type.hasAdapter?}}{{type.adapterTypeClassName}}
{{#else if (or type.binary? type.isBinaryString?)}}
{{#if field_hasAdapter}}io.netty.buffer.ByteBuf{{#else}}byte[]{{/if}}
{{! Recurse through every layer of typedef, as each layer could have an adapter }}
{{#else if type.typedef?}}{{#partial boxed_type type=type.resolved field_hasAdapter=field_hasAdapter}}
{{#else if type.void?}}Void
{{#else if type.bool?}}Boolean
{{#else if type.byte?}}Byte
{{#else if type.i16?}}Short
{{#else if type.i32?}}Integer
{{#else if type.i64?}}Long
{{#else if type.double?}}Double
{{#else if type.float?}}Float
{{#else if type.list?}}List<{{#partial boxed_type type=type.elem_type field_hasAdapter=field_hasAdapter}}>
{{#else if type.set?}}Set<{{#partial boxed_type type=type.elem_type field_hasAdapter=field_hasAdapter}}>
{{#else if (or type.structured? type.enum?)}}{{type.program.javaPackage}}.{{type.javaCapitalName}}
  {{#else if type.string?}}
String
  {{#else if type.map?}}
Map<
{{#partial boxed_type type=type.key_type field_hasAdapter=field_hasAdapter}}, {{!}}
{{#partial boxed_type type=type.val_type field_hasAdapter=field_hasAdapter}}
>
  {{/if type.java_type?}}
{{/let partial}}

{{! Resolves through typedef layers (that don't override java_type) before
    calling boxed_type. This produces the underlying concrete boxed type
    for container instantiation (e.g. HashSet, ArrayList, HashMap). }}
{{#let export partial resolved_boxed_type |type field_hasAdapter| captures |boxed_type|}}
  {{#pragma ignore-newlines}}
{{#if (and type.typedef? (not type.java_type?))}}{{#partial resolved_boxed_type type=type.resolved field_hasAdapter=field_hasAdapter}}
{{#else}}{{#partial boxed_type type=type field_hasAdapter=field_hasAdapter}}
{{/if (and type.typedef? (not type.java_type?))}}
{{/let partial}}

{{! Resolves the boxed type for Thrift serialization, handling binary/string
    types with adapter context for ByteBuf vs byte[] resolution.
    Recurses through typedefs one layer at a time. }}
{{#let export partial thrift_boxed_type |type field_hasAdapter| captures |boxed_type|}}
  {{#pragma ignore-newlines}}
{{#if type.java_type?}}{{type.java_type}}
{{#else if type.typedef?}}
  {{#if type.hasAdapter?}}
    {{#if type.true_type.binary?}}io.netty.buffer.ByteBuf
    {{#else if type.true_type.isBinaryString?}}io.netty.buffer.ByteBuf
    {{#else if type.true_type.string?}}String
    {{#else}}{{#partial thrift_boxed_type type=type.resolved field_hasAdapter=field_hasAdapter}}
    {{/if type.true_type.binary?}}
  {{#else}}
    {{#if type.isBinaryString?}}
      {{#if field_hasAdapter}}io.netty.buffer.ByteBuf{{#else}}byte[]{{/if field_hasAdapter}}
    {{#else}}{{#partial thrift_boxed_type type=type.resolved field_hasAdapter=field_hasAdapter}}
    {{/if type.isBinaryString?}}
  {{/if type.hasAdapter?}}
{{#else if type.binary?}}
  {{#if field_hasAdapter}}io.netty.buffer.ByteBuf{{#else}}byte[]{{/if field_hasAdapter}}
{{#else if type.string?}}
  {{#if type.isBinaryString?}}
    {{#if field_hasAdapter}}io.netty.buffer.ByteBuf{{#else}}byte[]{{/if field_hasAdapter}}
  {{#else}}String
  {{/if type.isBinaryString?}}
{{#else if type.map?}}
  Map<{{#partial thrift_boxed_type type=type.key_type field_hasAdapter=field_hasAdapter}}, {{#partial thrift_boxed_type type=type.val_type field_hasAdapter=field_hasAdapter}}>
{{#else if type.list?}}
  List<{{#partial thrift_boxed_type type=type.elem_type field_hasAdapter=field_hasAdapter}}>
{{#else if type.set?}}
  Set<{{#partial thrift_boxed_type type=type.elem_type field_hasAdapter=field_hasAdapter}}>
{{#else}}{{#partial boxed_type type=type field_hasAdapter=false}}
{{/if type.java_type?}}
{{/let partial}}

{{#let export partial java_type |type has_adapter_override| captures |boxed_type|}}
  {{#pragma ignore-newlines}}
{{#if type.java_type?}}{{type.java_type}}
{{#else if type.isBinaryString?}}{{#if has_adapter_override}}io.netty.buffer.ByteBuf{{#else}}byte[]{{/if}}
{{#else if type.typedef?}}{{#partial java_type type=type.resolved has_adapter_override=has_adapter_override}}
{{#else if type.void?}}void
{{#else if type.bool?}}boolean
{{#else if type.byte?}}byte
{{#else if type.i16?}}short
{{#else if type.i32?}}int
{{#else if type.i64?}}long
{{#else if type.double?}}double
{{#else if type.float?}}float
{{#else}}{{#partial boxed_type type=type field_hasAdapter=has_adapter_override}}
{{/if type.java_type?}}
{{/let partial}}

{{! Resolves the boxed type within an adapter context, propagating
    type_isAdapterSet=true through container element types. Unlike boxed_type,
    which resets type_isAdapterSet for container elements (to match mstch behavior),
    this partial maintains the adapter context through nested containers so that
    binary elements correctly resolve to ByteBuf instead of byte[]. }}
{{#let partial adapted_inner_boxed_type |type| captures |boxed_type|}}
  {{#pragma ignore-newlines}}
{{#if type.java_type?}}{{type.java_type}}
{{#else if type.hasAdapter?}}{{type.adapterTypeClassName}}
{{#else if (or type.binary? type.isBinaryString?)}}io.netty.buffer.ByteBuf
{{#else if type.typedef?}}{{#partial adapted_inner_boxed_type type=type.resolved}}
{{#else if type.list?}}List<{{#partial adapted_inner_boxed_type type=type.elem_type}}>
{{#else if type.set?}}Set<{{#partial adapted_inner_boxed_type type=type.elem_type}}>
{{#else if type.map?}}
Map<{{#partial adapted_inner_boxed_type type=type.key_type}}, {{#partial adapted_inner_boxed_type type=type.val_type}}>
{{#else}}
{{#partial boxed_type type=type field_hasAdapter=false}}
{{/if type.java_type?}}
{{/let partial}}

{{! Resolves the adapted boxed type for a typedef with an adapter.
    For the last adapter in a chain, gives the boxed type of the underlying type.
    For nested adapters, gives the typeClassName of the intermediate adapter. }}
{{#let export partial adapted_boxed_type |type| captures |boxed_type adapted_inner_boxed_type|}}
  {{#pragma ignore-newlines}}
{{#if type.java_type?}}{{type.java_type}}
  {{#else if type.typedef?}}
{{#if type.lastAdapter?}}{{#if type.isBinaryString?}}io.netty.buffer.ByteBuf{{#else}}{{#partial adapted_boxed_type type=type.resolved}}{{/if}}{{#else}}{{type.adapterTypeClassName}}{{/if}}
  {{#else}}
{{#partial adapted_inner_boxed_type type=type}}
  {{/if type.java_type?}}
{{/let partial}}

{{#let export partial adapted_type |type has_adapter_override| captures |java_type|}}
  {{#pragma ignore-newlines}}
{{#if type.java_type?}}{{type.java_type}}
{{#else if type.hasAdapter?}}{{type.adapterTypeClassName}}
{{#else}}{{#partial java_type type=type has_adapter_override=has_adapter_override}}
{{/if type.java_type?}}
{{/let partial}}

{{! Resolves the full Java type for a field, considering wrappers, adapters,
    and optionality (boxed for optional, unboxed for required). }}
{{#let export partial field_type |field| captures |boxed_type java_type|}}
  {{#pragma ignore-newlines}}
{{#if field.hasWrapper?}}{{field.wrapperType}}
{{#else if field.hasFieldAdapter?}}{{field.fieldAdapterTypeClassName}}
{{#else if field.type.hasAdapter?}}{{field.type.adapterTypeClassName}}
{{#else if field.optional?}}{{#partial boxed_type type=field.type field_hasAdapter=field.hasAdapter?}}
{{#else}}{{#partial java_type type=field.type has_adapter_override=field.hasAdapter?}}
{{/if field.hasWrapper?}}
{{/let partial}}

{{! Same as field_type but without considering wrappers. }}
{{#let export partial field_type_no_wrapper |field| captures |boxed_type java_type|}}
  {{#pragma ignore-newlines}}
{{#if field.hasFieldAdapter?}}{{field.fieldAdapterTypeClassName}}
{{#else if field.type.hasAdapter?}}{{field.type.adapterTypeClassName}}
{{#else if field.optional?}}{{#partial boxed_type type=field.type field_hasAdapter=field.hasAdapter?}}
{{#else}}{{#partial java_type type=field.type has_adapter_override=field.hasAdapter?}}
{{/if field.hasFieldAdapter?}}
{{/let partial}}

{{! Defines the mapping of a Thrift type to the Java TType constant name. }}
{{#let export partial ttype |type|}}
  {{#pragma ignore-newlines}}
{{#if type.typedef?}}{{#partial ttype type=type.true_type}}
{{#else if type.void?}}VOID
{{#else if type.string?}}STRING
{{#else if type.binary?}}STRING
{{#else if type.bool?}}BOOL
{{#else if type.byte?}}BYTE
{{#else if type.i16?}}I16
{{#else if type.i32?}}I32
{{#else if type.i64?}}I64
{{#else if type.float?}}FLOAT
{{#else if type.double?}}DOUBLE
{{#else if type.structured?}}STRUCT
{{#else if type.enum?}}I32
{{#else if type.list?}}LIST
{{#else if type.set?}}SET
{{#else if type.map?}}MAP
{{/if type.typedef?}}
{{/let partial}}

{{! Generates the getter method name for a field.
    Returns "is<Name>" for boolean fields and "get<Name>" for all others. }}
{{#let export partial getter_name |field|}}
  {{#pragma ignore-newlines}}
{{#if field.type.bool?}}is{{#else}}get{{/if}}{{field.javaCapitalName}}
{{/let partial}}

{{! Maps a field's qualifier to the Java Requiredness enum constant. }}
{{#let export partial requiredness |field|}}
  {{#pragma ignore-newlines}}
{{#if field.required?}}Requiredness.REQUIRED
{{#else if field.optional?}}Requiredness.OPTIONAL
{{#else if field.terse?}}Requiredness.TERSE
{{#else}}Requiredness.NONE
{{/if field.required?}}
{{/let partial}}

{{! Defines a Java default value for a given Thrift type.
    Recursively resolves through typedefs, returns zero-values for primitives,
    fromInteger(0) for enums, and null for everything else. }}
{{#let export partial java_default_value |type|}}
  {{#pragma ignore-newlines}}
{{#if type.typedef?}}{{#partial java_default_value type=type.true_type}}
{{#else if type.bool?}}false
{{#else if type.byte?}}0
{{#else if type.i16?}}0
{{#else if type.i32?}}0
{{#else if type.i64?}}0L
{{#else if type.float?}}0.f
{{#else if type.double?}}0.
{{#else if type.enum?}}{{type.program.javaPackage}}.{{type.javaCapitalName}}.fromInteger(0)
{{#else}}null
{{/if type.typedef?}}
{{/let partial}}

{{! Reads a binary value, using ByteBuf when in an adapter context
    (isAdapted from type-level propagation, or field_hasAdapter from
    field-level adapter), and byte[] otherwise. }}
{{#let export partial read_binary |type isAdapted field_hasAdapter|}}
  {{#pragma ignore-newlines}}
{{#if (or isAdapted field_hasAdapter)}}org.apache.thrift.protocol.TProtocolUtil.readBinaryAsByteBuf(oprot)
{{#else}}oprot.readBinary(){{#if (not type.java_type?)}}.array(){{/if (not type.java_type?)}}
{{/if (or isAdapted field_hasAdapter)}}
{{/let partial}}

{{! Resolves the Thrift type name, recursing through typedefs one layer at a time
    to check javaType at each layer. Falls back to java_type at the leaf.
    Only called from adapter contexts (type:hasAdapter? guards), so binary
    always resolves to ByteBuf. }}
{{#let export partial thrift_type |type| captures |java_type|}}
  {{#pragma ignore-newlines}}
{{#if type.java_type?}}{{type.java_type}}
{{#else if type.typedef?}}{{#partial thrift_type type=type.resolved}}
{{#else if (or type.binary? type.isBinaryString?)}}io.netty.buffer.ByteBuf
{{#else}}{{#partial java_type type=type has_adapter_override=false}}
{{/if type.java_type?}}
{{/let partial}}
