{{! Program docblock - Glean annotation for identifying thrift sources }}
{{#let export partial program_docblock}}
/** Glean {"file": "{{root_program.autogen_path}}"} */
{{/let partial}}

{{! Constant docblock - Glean annotation for mapping generated constants to thrift constants }}
{{#let export partial const_docblock |const|}}
/** Glean {"constant": "{{const.name}}"} */
{{/let partial}}

{{! Field docblock - Glean annotation for mapping generated methods to thrift fields }}
{{#let export partial field_docblock |field|}}
/** Glean { "field": "{{field.cpp_name}}" } */
{{/let partial}}

{{! Glean annotation to map generated functions to thrift enums. }}
{{#let export partial enum_docblock |enum|}}
/** Glean {"file": "{{enum.program.autogen_path}}", "name": "{{enum.cpp_name}}", "kind": "enum" } */
{{/let partial}}
