{{#let export partial param_type |type function|}}
{{#pragma ignore-newlines}}
  {{#if type.resolves_to_complex_return?}}
{{#if function.stack_arguments?}}const {{type.cpp_type}}&{{#else}}std::unique_ptr<{{type.cpp_type}}>{{/if}}
  {{#else}}
{{type.cpp_type}}
  {{/if type.resolves_to_complex_return?}}
{{/let partial}}

{{#let export partial return_type |function service|}}
{{#pragma ignore-newlines}}
{{#if function.creates_interaction?}}apache::thrift::TileAndResponse<apache::thrift::ServiceHandler<{{service.qualified_name}}>::{{function.created_interaction.cpp_name}}If, {{/if}}
  {{#if (and function.return_type.resolves_to_complex_return? (not function.sink_or_stream?))}}
{{#if function.stack_arguments?}}{{function.cpp_return_type}}{{#else}}std::unique_ptr<{{function.return_type.cpp_type}}>{{/if}}
  {{#else}}
{{function.cpp_return_type}}
  {{/if (and function.return_type.resolves_to_complex_return? (not function.sink_or_stream?))}}
{{#if function.creates_interaction?}}>{{/if}}
{{/let partial}}

{{#let export partial return_type_lift_unit |function service| captures |return_type|}}
{{#pragma ignore-newlines}}
{{#if function.void?}}folly::Unit{{#else}}{{#partial return_type function=function service=service}}{{/if}}
{{/let partial}}

{{#let export partial sync_return_type |function service| captures |return_type|}}
{{#pragma ignore-newlines}}
{{#if function.sync_returns_by_outparam?}}void{{#else}}{{#partial return_type function=function service=service}}{{/if}}
{{/let partial}}

{{#let export partial sync_return_param |function|}}
{{#pragma ignore-newlines}}
  {{#if function.sync_returns_by_outparam?}}
{{function.cpp_return_type}}& /*_return*/{{#if function.params.fields?}}, {{/if}}
  {{/if function.sync_returns_by_outparam?}}
{{/let partial}}

{{#let export partial function_param_list |function| captures |param_type|}}
{{#pragma ignore-newlines}}
  {{#each (array.enumerate function.params.fields with_first=true) as |i field is_first?|}}
{{#if (not is_first?)}}, {{/if}}{{#partial param_type type=field.type function=function}} p_{{field.cpp_name}}
  {{/each}}
{{/let partial}}

{{#let export partial function_param_list_commented_out |function| captures |param_type|}}
{{#pragma ignore-newlines}}
  {{#each (array.enumerate function.params.fields with_first=true) as |i field is_first?|}}
{{#if (not is_first?)}}, {{/if}}{{#partial param_type type=field.type function=function}} /*{{field.cpp_name}}*/
  {{/each}}
{{/let partial}}
