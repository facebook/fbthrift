{{! Partials shared between RPC client and server codegen }}

{{#let export partial function_name |service function|}}
{{#pragma ignore-newlines}}
{{#if service.interaction?}}{{service.name}}.{{/if}}{{function.name}}
{{/let partial}}

{{#let export partial param_list |function|}}
{{#pragma ignore-newlines}}
  {{#each (array.enumerate function.params.fields with_first=true) as |i field is_first?|}}
{{#if (not is_first?)}}, {{/if}}p_{{field.cpp_name}}
  {{/each}}
{{/let partial}}

{{#let export partial function_kind |function|}}
{{#pragma ignore-newlines}}
apache::thrift::RpcKind::
{{#if function.oneway?}}SINGLE_REQUEST_NO_RESPONSE
{{#else if function.bidirectional_stream?}}BIDIRECTIONAL_STREAM
{{#else if function.stream?}}SINGLE_REQUEST_STREAMING_RESPONSE
{{#else if function.sink?}}SINK
{{#else}}SINGLE_REQUEST_SINGLE_RESPONSE
{{/if function.oneway?}}
{{/let partial}}
